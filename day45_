/*
WAF to calculation between two numbers
*/

#include<stdio.h>
  void add(int a,int b)
{
  printf("sum is %d",a+b);
}
  void sub(int a,int b)
{
  printf("sub is %d",a-b);
}
  void mul(int a,int b)
{
  printf("mul is %d",a*b);
}
  int main()
{
  int num1,num2;
  scanf("%d %d",&num1,&num2);
  add(num1,num2);
  sub(num1,num2);
  mul(num1,num2);
}
