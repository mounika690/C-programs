/*
CALL BY REFERENCE :
->the madifications doesn't reflect it later eventhough you changed

EX:

void change(int *x) {
    *x = 100;
}

int main() {
    int a = 10;
    change(&a);
    printf("%d", a); // changed to  100 bcz we are overwriting with 100
}
*/
