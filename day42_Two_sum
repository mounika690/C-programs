/*
WAP to print which elements give sum of array elements equal to n 
*/


#include<stdio.h>
  int main()
{
  int size;
  scanf("%d",&size);
  int arr[size];
  for(int i=0;i<size;i++)
  {
    scanf("%d",&arr[i]);
  }
  int n,sum;
  scanf("%d",&n);
  for(int i=0;i<size;i++)
  {
    for(int j=i+1;j<size;j++)
    {
      sum = arr[i] + arr[j];
      if(sum == n)
      {
        printf("%d %d\n",arr[i],arr[j]);
        break;
      }
    }
  }
}
      
