/*
WAP to print all prime numbers between 1 to 100
*/

#include <stdio.h>
#include <math.h>
int main() 
{
    int count;
  for(int i=1;i<=100;i++)
  {
    count =0;
    for(int j=2;j*j<=i;j++)
    {
      if(i%j==0)
      {
        count++;
        break;
      }
    }
    if(count == 0)
    {
      printf("%d is prime number\n",i);
    }
  }
}
