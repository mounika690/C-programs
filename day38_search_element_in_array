/*
WAP to search element present in array or not
*/

#include<stdio.h>
  int main()
{
  int size;
  scanf("%d",&size);
  int arr[size];
  for(int i=0;i<size;i++)
  {
    scanf("%d",&arr[i]);
  }
  int ele;
  scanf("%d",&ele);
  for(int i=0;i<size;i++)
  {
    if(arr[i] == ele)
    {
      printf("%d is found",ele);
      break;
    }
  }
}
