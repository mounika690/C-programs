/*
WAP to print array elements
*/

#include<stdio.h>
  int main()
{
  int arr[5]={1,2,3,4,5};
  //if you want print one element at time use like this
  printf("%d ",arr[0]);
  printf("%d ",arr[1]);
  printf("%d ",arr[2]);
  printf("%d ",arr[3]);
  printf("%d ",arr[4]);
  //all elements at one time in a loop
  for(int i=0;i<5;i++)
  {
    printf("%d ",arr[i]);
  }
}
  
