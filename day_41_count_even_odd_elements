/*WAP to count odd_even_elements in an array
*/

#include<stdio.h>
  int main()
{
  int size;
  scanf("%d",&size);
  int arr[size];
  for(int i=0;i<size;i++)
  {
    scanf("%d",&arr[i]);
  }
  int odd_count=0,even_count=0;
  for(int i=0;i<size;i++)
  {
    if(arr[i]%2 == 0)
    {
      even_count++;}
    else
    {
      odd_count++;
    }
  }
  printf("%d",even_count);
  printf("%d",odd_count);
}
