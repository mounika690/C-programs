/*
WAP to print even and odd array elements
*/


#include<stdio.h>
int main()
{
  int size;
  scanf("%d",&size);//reading no of elements user want
  int arr[size];
  for(int i=0;i<size;i++)
  {
    scanf("%d",&arr[i]);//reading elements from user
  }
  printf("even elements\n");
  for(int i=0;i<size;i++)
  {
    if(arr[i]%2==0)//checking whether even number or not
    {
      printf("%d ",arr[i]);
    }
  }
  printf("odd elements\n");
  for(int i=0;i<size;i++)
  {
    if(arr[i]%2!=0)//checking whether odd number or not
    {
      printf("%d ",arr[i]);
    }
  }
