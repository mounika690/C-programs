/*For Loop
What it does: Repeat a task a fixed number of times.
Example: Print numbers 0 to 4
*/

#include <stdio.h>

int main() {
    for(int i = 0; i < 5; i++) {
        printf("%d\n", i);
    }
    return 0;
}


/*
OUTPUT :
0
1
2
3
4


Explanation:
1.i=0 → start
2.Check condition i<5 → true → print i → increment i++
3.Repeat until i<5 is false

*/
