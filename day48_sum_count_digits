/*
WAF to calculate the sum of digits in a number
*/

#include<stdio.h>
  void sum(int num)
{
  int sum = 0,rem,count=0;
  while(num)
  {
  rem = num%10;
  sum = sum+rem;
    count++;
  num=num/10;
  }
  printf("%d is sum of digits in a number",sum);
  printf("%d is no of digits in a number",count);
}
  int main()
{
  int num;
  scanf("%d",&num);
  sum(num);
}
