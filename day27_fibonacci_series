/*
WAP to fibonacci series until user entered number
*/

#include<stdio.h>
  int main()
{
  int num;
  scanf("%d",&num);//reading number from user
  int first =0,second =1,next;
  printf("factorial series"\n);
  for(int i=0;i<=num;i++)
  {
    printf("%d ",first);
    next = first+second;
    first =second;
    second =next;
  }
}
