/*
Write a program to check if a number is:
->Divisible by both 3 and 5
*/

#include<stdio.h>
  int main()
{
  int num;
  scanf("%d",&num);
  if(num%3==0)
  {
    if(num%5==0)
    {
      printf("%d is divisible by 3 and 5",num);
    }
  }
  else
  {
    printf("%d is not divisible by 3 and 5",num);
  }
}
