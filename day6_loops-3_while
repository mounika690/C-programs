/*What it does: Repeat as long as a condition is true.
Example: Print numbers 0 to 4
*/

#include <stdio.h>

int main() 
{
    int i = 0;
    while(i < 5) 
    {
        printf("%d\n", i);
        i++;
    }
    return 0;
}
/*
OUTPUT :
0
1
2
3
4


Explanation:
1.Start with i=0
2.Check condition i<5 → true → print i → increase i
3.Stops when i reaches 5  
*/
