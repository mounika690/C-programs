/*Identifying the whether the number is positive or not*/

#include <stdio.h>

int main() {
    int num;
    scanf("%d", &num);//reading a number

//checking conditions and printing 
    if (num > 0) {
        printf("Positive");
    } else if (num < 0) {
        printf("Negative");
    } else {
        printf("Zero");
    }

    return 0;
